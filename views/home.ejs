<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeBot | The AI Coding Revolution</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Dark Theme */
            --bg: #0a0a0a;
            --surface: #141414;
            --text: #ffffff;
            --text-dim: #a1a1aa;
            --primary: #22c55e;
            --primary-glow: rgba(34, 197, 94, 0.15);
            --accent: #3b82f6;
            --border: #27272a;
            --glass: rgba(10, 10, 10, 0.95);
        }

        [data-theme="light"] {
            --bg: #ffffff;
            --surface: #f4f4f5;
            --text: #09090b;
            --text-dim: #71717a;
            --primary: #16a34a;
            --primary-glow: rgba(22, 163, 74, 0.1);
            --accent: #2563eb;
            --border: #e4e4e7;
            --glass: rgba(255, 255, 255, 0.95);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            transition: background 0.3s ease;
            overflow-x: hidden;
        }

        /* --- Updated Navbar --- */
        nav {
            position: fixed; top: 0; width: 100%;
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 5%;
            background: var(--glass);
            backdrop-filter: blur(12px);
            z-index: 1000;
            border-bottom: 1px solid var(--border);
        }

        .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 8px; z-index: 1001; }
        
        .nav-links { display: flex; gap: 1.5rem; align-items: center; transition: 0.3s ease-in-out; }
        .nav-links a { text-decoration: none; color: var(--text); font-weight: 500; font-size: 0.9rem; opacity: 0.8; transition: 0.3s; }
        .nav-links a:hover { opacity: 1; color: var(--primary); }

        /* Hamburger Menu Icon */
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            z-index: 1001;
            padding: 5px;
        }

        .menu-toggle span {
            width: 25px;
            height: 2px;
            background-color: var(--text);
            transition: 0.3s;
        }

        #theme-toggle {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
        }

        /* Hero Section */
        .hero {
            padding: 160px 5% 100px;
            text-align: center;
            background: radial-gradient(circle at 50% -20%, var(--primary-glow), transparent 50%);
        }

        .hero h1 { 
            font-size: clamp(2.5rem, 8vw, 5rem); 
            font-weight: 800; 
            letter-spacing: -3px; 
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .hero p { 
            max-width: 650px; margin: 0 auto 40px; 
            font-size: 1.1rem; color: var(--text-dim);
            line-height: 1.6;
        }

        .cta-group { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .btn { padding: 12px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.3s; text-decoration: none; border: none; }
        .btn-primary { background: var(--primary); color: white; box-shadow: 0 10px 20px -5px var(--primary-glow); }
        .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }

        /* Sections & Grids */
        .section { padding: 80px 5%; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
        .card { background: var(--surface); padding: 30px; border-radius: 20px; border: 1px solid var(--border); }

        /* --- Mobile Responsive Styles --- */
        @media (max-width: 768px) {
            .menu-toggle { display: flex; }

            .nav-links {
                position: fixed;
                top: 0;
                right: -100%; /* Hidden by default */
                height: 100vh;
                width: 70%;
                background: var(--surface);
                flex-direction: column;
                justify-content: center;
                align-items: center;
                box-shadow: -10px 0 30px rgba(0,0,0,0.3);
                z-index: 1000;
            }

            .nav-links.active {
                right: 0; /* Slide in */
            }

            .nav-links a, #theme-toggle {
                font-size: 1.2rem;
                width: 80%;
                text-align: center;
            }

            .hero h1 { font-size: 2.5rem; }
            .hero { padding: 120px 5% 60px; }
            
            /* Animation for hamburger to X */
            .active .line1 { transform: rotate(-45deg) translate(-5px, 6px); }
            .active .line2 { opacity: 0; }
            .active .line3 { transform: rotate(45deg) translate(-5px, -6px); }
        }

        /* Stats & Slider styling remains mostly same */
        .stats-section { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; padding: 40px 5%; }
        .stat-item { text-align: center; min-width: 120px; }
        .terminal-container { padding: 0 5%; margin-bottom: 50px; }
        .terminal { max-width: 900px; margin: 0 auto; background: #000; border-radius: 12px; border: 1px solid var(--border); overflow: hidden; }
        .term-body { padding: 20px; font-family: 'Fira Code', monospace; color: #a1a1aa; font-size: 13px; }
        
        .slider-container { background: var(--surface); padding: 20px 0; overflow: hidden; white-space: nowrap; border-top: 1px solid var(--border); }
        .slider { display: inline-block; animation: slide 20s linear infinite; }
        .slider span { font-size: 1.2rem; font-weight: 800; margin: 0 25px; color: var(--text-dim); opacity: 0.4; }
        @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        footer { padding: 60px 5% 20px; background: var(--surface); border-top: 1px solid var(--border); }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 30px; }
    </style>
</head>
<body data-theme="dark">

    <nav>
        <div class="logo"><span>⚡</span> CodeBot</div>
        
        <div class="menu-toggle" id="mobile-menu">
            <span class="line1"></span>
            <span class="line2"></span>
            <span class="line3"></span>
        </div>

        <div class="nav-links" id="nav-content">
            <button id="theme-toggle" onclick="toggleTheme()">☀️ Light Mode</button>
            <a href="/login" class="btn btn-secondary">Login</a>
            <a href="/signup" class="btn btn-primary" style="color:white">Signup</a>
        </div>
    </nav>

    <header class="hero">
        <h1>Your AI <span>Code-Bot</span> for the Future.</h1>
        <p>CodeBot doesn't just write code; it thinks like a developer. Debug, refactor, and deploy with ease.</p>
        <div class="cta-group">
            <a href="/demo" class="btn btn-primary">Start Chatting Free</a>
            <a href="#features" class="btn btn-secondary">Explore Features</a>
        </div>
    </header>

    <section class="stats-section">
        <div class="stat-item"><h2>10M+</h2><p>Lines Fixed</p></div>
        <div class="stat-item"><h2>50k+</h2><p>Active Devs</p></div>
        <div class="stat-item"><h2>99%</h2><p>Accuracy</p></div>
    </section>

    <div class="terminal-container">
        <div class="terminal">
            <div class="term-body">
                <p style="color: #22c55e;">> codebot --refactor profile.js</p>
                <p>> Optimizing database calls...</p>
                <p style="color: #3b82f6;">> [Done] Performance improved by 40%.</p>
            </div>
        </div>
    </div>

    <div class="slider-container">
        <div class="slider">
            <span>REACT</span><span>PYTHON</span><span>DOCKER</span><span>NEXT.JS</span><span>RUST</span><span>NODE.JS</span><span>GO</span><span>AWS</span>
            <span>REACT</span><span>PYTHON</span><span>DOCKER</span><span>NEXT.JS</span><span>RUST</span><span>NODE.JS</span><span>GO</span><span>AWS</span>
        </div>
    </div>

    <section id="features" class="section">
        <div class="grid">
            <div class="card">
                <h3>Intelligent Debugging</h3>
                <p>Traces stack flows and finds logic flaws in seconds.</p>
            </div>
            <div class="card">
                <h3>Security Audit</h3>
                <p>Scans for vulnerabilities before you push to production.</p>
            </div>
            <div class="card">
                <h3>Auto Docs</h3>
                <p>Generates clean documentation from your raw source code.</p>
            </div>
        </div>
    </section>

    <footer>
        <div class="footer-grid">
            <div class="footer-col"><h4>Product</h4><a href="#">Security</a><a href="#">CLI Tool</a></div>
            <div class="footer-col"><h4>Support</h4><a href="#">Docs</a><a href="#">Contact</a></div>
        </div>
        <p style="text-align:center; margin-top:40px; font-size:0.8rem; color:var(--text-dim)">&copy; 2026 CodeBot AI Inc.</p>
    </footer>

    <script>
        // Toggle Mobile Menu
        const mobileMenu = document.getElementById('mobile-menu');
        const navLinks = document.getElementById('nav-content');

        mobileMenu.addEventListener('click', () => {
            navLinks.classList.toggle('active');
            mobileMenu.classList.toggle('active');
        });

        // Close menu when a link is clicked
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('click', () => {
                navLinks.classList.remove('active');
                mobileMenu.classList.remove('active');
            });
        });

        // Theme Toggle Logic
        function toggleTheme() {
            const body = document.body;
            const btn = document.getElementById('theme-toggle');
            if (body.getAttribute('data-theme') === 'dark') {
                body.setAttribute('data-theme', 'light');
                btn.innerHTML = "🌙 Dark Mode";
            } else {
                body.setAttribute('data-theme', 'dark');
                btn.innerHTML = "☀️ Light Mode";
            }
        }
    </script>
</body>
</html>